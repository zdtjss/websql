# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.syso

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include)
# vendor/
go.sum

# Secrets / certificates
nway.key
nway.pem

# IDE
.vscode/
.idea/

# Database files
*.db
*.db-shm
*.db-wal
nway.s3db

# Logs
*.log
logs/

# Runtime data
/data
/exports
backups/
screenshots/
__pycache__/

# Build / release artifacts
/static/
release/
dist-pack/
.release-staging/
build/
.dbg/
.kiro/

# Frontend generated
web-src/package-lock.json
web-src/auto-imports.d.ts
web-src/components.d.ts
web-src/static

# Desktop build artifacts
cmd/desktop/frontend/
cmd/desktop/migrations/
